# Development Dockerfile
FROM node:18-alpine

RUN apk add --no-cache openssl

WORKDIR /app

# Set Prisma environment variables for Alpine Linux
ENV PRISMA_QUERY_ENGINE_BINARY=/app/node_modules/.prisma/client/libquery_engine.so.node

COPY package*.json ./
COPY prisma ./prisma

# Install all dependencies including dev dependencies
RUN npm install

COPY . .

# Generate Prisma client (skip if binaries can't be downloaded - will regenerate at runtime)
RUN npx prisma generate || echo "Prisma generate failed during build, will retry at runtime"

EXPOSE 5000

# Development uses nodemon for hot reload
CMD sh -c "npx prisma generate && npm start"
